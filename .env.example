PORT=8787
# 监听地址：默认仅本机回环，避免内网无鉴权直连。如需 Prometheus 远程抓取 /metrics，
# 改为 0.0.0.0 并务必设置 PANEL_TOKEN。
BIND_HOST=127.0.0.1
# 访问令牌（可选）：设置后 /api 与 /metrics 需携带 x-panel-token / Bearer / ?token
PANEL_TOKEN=
LAN_DOMAIN_SUFFIX=home.sooua.net

PRIMARY_NAME=a-nas
PRIMARY_HOST=10.0.0.10
PRIMARY_USER=sooua
PRIMARY_PASSWORD=change-me
PRIMARY_CADDY_IP=10.0.0.20

BACKUP_NAME=b-nas
BACKUP_HOST=10.0.0.11
BACKUP_USER=eoovoi
BACKUP_PASSWORD=change-me
BACKUP_CADDY_IP=10.0.0.21

CADDY_DIR=/volume1/docker/caddy-ha
CADDY_CONTAINER=caddy-ha

# 监控与告警（均可选）
# 证书剩余天数低于此值视为告警
CERT_WARN_DAYS=14
# 后台看护轮询周期（秒）
WATCH_INTERVAL_SEC=60
# 告警推送目标（任选其一或都不填；不填则仅在面板内展示告警）
# 已有内网 Alertmanager 时填它，告警走你现有的通知策略：
ALERTMANAGER_URL=
# 或填一个通用 webhook（Server酱 / 企业微信 / 自建接收端）：
WEBHOOK_URL=
# 推送告警时携带的实例标识
PANEL_INSTANCE=caddy-panel
